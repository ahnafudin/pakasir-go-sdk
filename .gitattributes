# Normalize line endings to LF on checkin for all text files.
# Prevents CRLF/LF churn between Windows and Unix contributors.
* text=auto eol=lf

# Go toolchain files are always LF.
*.go    text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf

# Docs and config.
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary files — never normalize.
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
